# Скопируй этот файл в .env и заполни реальные значения локально.
# .env, secrets/, базы данных и логи НЕ коммитить в git.

# App
APP_SECRET=change-me-in-production
DB_FILE=family_shield.db

# LLM classifier
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_FALLBACK_MODEL=deepseek/deepseek-chat
SCAM_SCORE_THRESHOLD=0.85

# ASR: OpenRouter STT primary
OPENROUTER_STT_URL=https://openrouter.ai/api/v1/audio/transcriptions
OPENROUTER_STT_MODEL=openai/whisper-large-v3

# ASR fallbacks
SALUTE_SPEECH_API_KEY=
SALUTE_SPEECH_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
SALUTE_SPEECH_SCOPE=SALUTE_SPEECH_PERS
SALUTE_SPEECH_URL=https://smartspeech.sber.ru/rest/v1/speech:recognize
NEURO_NET_API_KEY=
NEURO_NET_URL=https://api.neuro.net/api/v1/recognize

# SMS providers
SMSAERO_EMAIL=
SMSAERO_API_KEY=
SMSAERO_SIGN=

# Legacy SMSC settings, kept only if old code paths are used
SMSC_LOGIN=
SMSC_PASSWORD=
SMSC_SENDER=

# Firebase Cloud Messaging
# Положи реальный service account JSON в secrets/ локально.
FCM_SERVICE_ACCOUNT_PATH=./secrets/fcm-service-account.json
# Legacy FCM server key устарел; оставь пустым, если не используешь старый код.
FCM_SERVER_KEY=

# Audio stream
PCM_SAMPLE_RATE=16000
PCM_CHUNK_DURATION_SEC=8
